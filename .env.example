# ============================================================
# DDoS Detection System — Environment Configuration
# ============================================================
# Copy this file to .env and update with your values

# ─── Application Settings ───────────────────────────────────
APP_NAME=ddos-detection-system
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-secure-random-string

# ─── API Server ─────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_CORS_ORIGINS=http://localhost:8080,http://localhost:3000
REQUIRE_HTTPS=false

# ─── WebSocket ──────────────────────────────────────────────
WS_HOST=0.0.0.0
WS_PORT=8001
WS_HEARTBEAT_INTERVAL=30

# ─── Dashboard ──────────────────────────────────────────────
DASHBOARD_PORT=8080

# Live packet capture. Default remains simulation.
# Set CAPTURE_TARGET_HOST=all or leave it empty to monitor all local IP traffic.
# On Windows, CAPTURE_INTERFACE=auto follows the adapter carrying the default route.
# TSHARK_PATH=tshark checks PATH first, then common Windows Wireshark install paths.
CAPTURE_SOURCE=simulation
CAPTURE_INTERFACE=auto
CAPTURE_TARGET_HOST=
CAPTURE_TARGET_PORTS=80,443
TSHARK_PATH=tshark
CAPTURE_BATCH_SIZE=200
CAPTURE_IDLE_TIMEOUT_SECONDS=10

# ─── Kafka Configuration ────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092,localhost:9093,localhost:9094
KAFKA_TOPIC_RAW_PACKETS=raw-packets
KAFKA_TOPIC_PROCESSED=processed-features
KAFKA_TOPIC_ALERTS=detection-alerts
KAFKA_CONSUMER_GROUP=ddos-detector
KAFKA_REPLICATION_FACTOR=3
KAFKA_NUM_PARTITIONS=12

# ─── Spark Configuration ────────────────────────────────────
SPARK_MASTER=local[*]
SPARK_APP_NAME=ddos-stream-processor
SPARK_BATCH_INTERVAL=1
SPARK_CHECKPOINT_DIR=/tmp/spark-checkpoints

# ─── ML Model Settings ──────────────────────────────────────
MODEL_DIR=./models
ISOLATION_FOREST_CONTAMINATION=0.05
AUTOENCODER_LATENT_DIM=32
AUTOENCODER_THRESHOLD_PERCENTILE=95
ENSEMBLE_WEIGHTS=0.3,0.4,0.3
TRAINING_UPLOAD_DIR=./data/uploads/cicddos2019
TRAINING_MAX_UPLOAD_BYTES=5368709120
TRAINING_MAX_ROWS_PER_CLASS=100000

# ─── Alert Settings ─────────────────────────────────────────
ALERT_RATE_LIMIT=100
ALERT_COOLDOWN_SECONDS=300
ALERT_ESCALATION_TIMEOUT=600

# Response automation. Monitor mode records would-block actions only.
RESPONSE_MODE=monitor
AUTO_BLOCK_ENABLED=false
RESPONSE_KILL_SWITCH=true
MITIGATION_ACTIVATION_ALLOWED=false
RESPONSE_API_TOKEN=
BLOCK_TTL_SECONDS=1800
AUTO_BLOCK_MAX_IPS_PER_ALERT=5
MAX_BLOCKS_PER_MINUTE=10
MAX_ACTIVE_BLOCKS=100
BLOCK_ALLOWLIST=127.0.0.1,::1,0.0.0.0,255.255.255.255,224.0.0.0/4,ff00::/8
FIREWALL_BACKEND=auto

# Local Wi-Fi/USB protection. Monitor mode creates alerts only.
LOCAL_THREAT_MONITOR_ENABLED=true
LOCAL_THREAT_SCAN_INTERVAL_SECONDS=30
LOCAL_THREAT_RESPONSE_MODE=monitor
LOCAL_THREAT_AUTO_DISCONNECT=false
LOCAL_THREAT_AUTO_DISABLE_ADAPTERS=false
LOCAL_THREAT_ENFORCEMENT_ALLOWED=false
TRUSTED_WIFI_SSIDS=
TRUSTED_WIFI_BSSIDS=
TRUSTED_USB_ADAPTER_KEYWORDS=
CAPTIVE_PORTAL_CHECK_ENABLED=true
CAPTIVE_PORTAL_TEST_URL=http://www.msftconnecttest.com/connecttest.txt
CAPTIVE_PORTAL_EXPECTED_TEXT=Microsoft Connect Test

# Enterprise passive wireless intelligence integrated into local-security scans.
WIRELESS_INTELLIGENCE_ENABLED=true
WIRELESS_OUI_DATABASE_PATH=./data/enterprise_oui.txt
WIRELESS_SUSPICIOUS_OUIS=00:13:37,D8:EB:46,00:C0:CA,00:8F:DF,6C:E8:73
WIRELESS_SUSPICIOUS_SSID_PATTERNS=Pineapple,Free Public WiFi,HACKED,Pwned,evil_twin,karma
WIRELESS_MULTI_SSID_THRESHOLD=3

# ─── Integration Keys (Replace with real values) ────────────
PAGERDUTY_API_KEY=
PAGERDUTY_SERVICE_ID=
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#security-alerts
SIEM_HOST=
SIEM_PORT=514
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=ddos-alerts@example.com
JIRA_URL=
JIRA_USERNAME=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=SEC

# ─── Prometheus Metrics ─────────────────────────────────────
PROMETHEUS_PORT=9090
METRICS_ENABLED=true

# ─── Database (for alert persistence) ───────────────────────
DATABASE_URL=sqlite:///./ddos_detection.db

# ─── JWT Authentication ─────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
